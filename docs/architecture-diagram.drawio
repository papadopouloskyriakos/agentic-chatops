        <!-- ═══ TIER 1: OpenClaw ═══ -->
        <mxCell id="group-t1" value="Tier 1 — OpenClaw (GPT-5.1)" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;rounded=1;fontSize=12;" vertex="1" parent="1">
