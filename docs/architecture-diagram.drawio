        <!-- ═══ TITLE ═══ -->
        <mxCell id="header" value="&lt;b&gt;agentic-chatops — Platform Architecture&lt;/b&gt;&lt;br&gt;3 Subsystems • 17 Workflows • 47 Runner Nodes • 10 MCP Servers • 10 Sub-Agents • 98 Eval Scenarios" style="text;html=1;align=center;fontSize=15;fillColor=none;strokeColor=none;" vertex="1" parent="1">
