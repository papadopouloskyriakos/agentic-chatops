        <!-- ═══ n8n ORCHESTRATOR ═══ -->
        <mxCell id="group-n8n" value="n8n Orchestrator (17 workflows, ~403 nodes)" style="swimlane;startSize=25;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;rounded=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="330" y="100" width="550" height="430" as="geometry" />
        </mxCell>

        <!-- Receivers row -->
        <mxCell id="recv-row" value="&lt;b&gt;8 Webhook Receivers&lt;/b&gt; (NL+GR pairs: LibreNMS, Prometheus, CrowdSec, Security) + Synology + WAL Healer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="35" width="520" height="35" as="geometry" />
        </mxCell>

        <!-- Dedup -->
        <mxCell id="node-dedup" value="&lt;b&gt;Dedup &amp; Burst Detection&lt;/b&gt;&lt;br&gt;Per-hostname dedup • Flap tracking • Recovery TTL (4h) • Burst: 3+ hosts in 5min → correlated-triage • Auto-escalation after 2+ flaps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#996185;fontSize=10;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="85" width="520" height="50" as="geometry" />
        </mxCell>

        <!-- Runner -->
        <mxCell id="node-runner" value="&lt;b&gt;Claude Gateway Runner (47 nodes)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Cooldown → Slot Lock → &lt;b&gt;Query Knowledge&lt;/b&gt; (hybrid RRF search) → &lt;b&gt;Build Prompt&lt;/b&gt; (XML-tagged RAG + defensive prompt + tool profiles + ReAct + few-shot)&lt;br&gt;→ Launch Claude (nohup, JSONL) → Fire Poller → Wait → &lt;b&gt;Parse Response&lt;/b&gt; (confidence, tool counts, token tracking)&lt;br&gt;→ Validation Retry (2x) → &lt;b&gt;Prepare Result&lt;/b&gt; (16 PII patterns, credential scan, fact-check)&lt;br&gt;→ &lt;b&gt;Evaluator-Optimizer&lt;/b&gt; (Haiku screens if confidence &amp;lt; 0.6 OR cost &amp;gt; €3) → Post to Matrix" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="150" width="520" height="120" as="geometry" />
        </mxCell>

        <!-- Bridge -->
        <mxCell id="node-bridge" value="&lt;b&gt;Matrix Bridge (73 nodes)&lt;/b&gt;&lt;br&gt;Polls /sync every 30s • Routes !commands • Reaction approval (👍/👎) • MSC3381 interactive polls • Session resume with context • Per-slot locking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="285" width="520" height="55" as="geometry" />
        </mxCell>

        <!-- Session End + Poller -->
        <mxCell id="node-poller" value="&lt;b&gt;Progress Poller&lt;/b&gt;&lt;br&gt;JSONL stream → Matrix m.notice (30s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=10;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="355" width="250" height="45" as="geometry" />
        </mxCell>
