        <mxCell id="db-knowledge" value="&lt;b&gt;Knowledge Sources&lt;/b&gt;&lt;br&gt;55 CLAUDE.md files • 200+ memories&lt;br&gt;55 agent diary entries (10 types)&lt;br&gt;33 incidents • 27 lessons • Plan-and-Execute" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="group-data">
