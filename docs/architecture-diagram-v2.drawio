          <mxGeometry x="15" y="355" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- ═══ n8n ORCHESTRATOR ═══ -->
        <mxCell id="group-n8n" value="n8n Orchestrator (25 workflows, ~475 nodes)" style="swimlane;startSize=25;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;rounded=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="330" y="100" width="550" height="460" as="geometry" />
        </mxCell>

        <!-- Receivers row -->
        <mxCell id="recv-row" value="&lt;b&gt;10 Webhook Receivers&lt;/b&gt; (NL+GR pairs: LibreNMS, Prometheus, CrowdSec, Security) + Synology + WAL Healer + CI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="35" width="520" height="35" as="geometry" />
        </mxCell>

        <!-- Dedup -->
        <mxCell id="node-dedup" value="&lt;b&gt;Dedup &amp; Burst Detection&lt;/b&gt;&lt;br&gt;Per-hostname dedup • Flap tracking • Recovery TTL (4h) • Burst: 3+ hosts in 5min → correlated-triage • CrowdSec auto-suppression" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#996185;fontSize=10;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="85" width="520" height="50" as="geometry" />
        </mxCell>

        <!-- Runner -->
        <mxCell id="node-runner" value="&lt;b&gt;Claude Gateway Runner (48 nodes)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Cooldown → Slot Lock → &lt;b&gt;Query Knowledge&lt;/b&gt; (4-signal hybrid RRF) → &lt;b&gt;Build Plan&lt;/b&gt; (Haiku planner, 8 categories)&lt;br&gt;→ &lt;b&gt;Build Prompt&lt;/b&gt; (investigation plan + XML-tagged RAG + staleness warnings + tool profiles + ReAct)&lt;br&gt;→ Launch Claude (nohup, JSONL) → Fire Poller → Wait → &lt;b&gt;Parse Response&lt;/b&gt; (confidence, tool counts, tokens)&lt;br&gt;→ Validation Retry (2x) → &lt;b&gt;Prepare Result&lt;/b&gt; (17 PII patterns, credential scan)&lt;br&gt;→ Evaluator-Optimizer (Haiku screen) → Post to Matrix" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="150" width="520" height="130" as="geometry" />
        </mxCell>

        <!-- Bridge -->
        <mxCell id="node-bridge" value="&lt;b&gt;Matrix Bridge (73 nodes)&lt;/b&gt;&lt;br&gt;Polls /sync every 30s • Routes !commands • Reaction approval (👍→session_feedback) • MSC3381 polls • Session resume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="295" width="520" height="55" as="geometry" />
        </mxCell>

        <!-- Session End + Poller -->
        <mxCell id="node-poller" value="&lt;b&gt;Progress Poller&lt;/b&gt;&lt;br&gt;JSONL stream → Matrix m.notice (30s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=10;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="365" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="node-end" value="&lt;b&gt;Session End (16 nodes)&lt;/b&gt;&lt;br&gt;Score Trajectory → Judge → Archive Transcript → Export Traces → KB → Graph → YT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;" vertex="1" parent="group-n8n">
          <mxGeometry x="280" y="365" width="255" height="45" as="geometry" />
        </mxCell>

        <!-- Stats APIs -->
        <mxCell id="node-apis" value="&lt;b&gt;3 Stats APIs&lt;/b&gt; agentic-stats • lab-stats • mesh-stats" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;" vertex="1" parent="group-n8n">
          <mxGeometry x="15" y="420" width="520" height="25" as="geometry" />
