        <mxCell id="db-grafana" value="&lt;b&gt;Grafana&lt;/b&gt;&lt;br&gt;9 custom dashboards&lt;br&gt;127 panels&lt;br&gt;+ OpenObserve datasource" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="group-data">
