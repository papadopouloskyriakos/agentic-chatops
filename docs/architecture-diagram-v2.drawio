        <!-- ═══ TIER 1: OpenClaw ═══ -->
        <mxCell id="group-t1" value="Tier 1 — OpenClaw (GPT-5.1)" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;rounded=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="940" y="100" width="290" height="220" as="geometry" />
        </mxCell>
        <mxCell id="t1-desc" value="&lt;b&gt;Fast triage: 7-21 seconds&lt;/b&gt;&lt;br&gt;&lt;br&gt;15 native skills (infra, K8s, security, correlated)&lt;br&gt;Hybrid RAG: 4-signal RRF + query rewriting&lt;br&gt;Confidence gate: &amp;lt; 0.7 → escalate to Tier 2&lt;br&gt;Handles 80%+ of alerts without escalation" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;fontSize=10;" vertex="1" parent="group-t1">
          <mxGeometry x="10" y="30" width="270" height="110" as="geometry" />
        </mxCell>
        <mxCell id="t1-guard" value="&lt;b&gt;Guardrails:&lt;/b&gt; safe-exec.sh (30+ blocks) • exec-approvals (36 patterns) • SOUL.md READ-ONLY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="group-t1">
          <mxGeometry x="10" y="150" width="270" height="35" as="geometry" />
        </mxCell>
        <mxCell id="t1-badge-ops" value="ChatOps" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;fontStyle=1;size=8;" vertex="1" parent="group-t1">
          <mxGeometry x="10" y="192" width="70" height="22" as="geometry" />
        </mxCell>
        <mxCell id="t1-badge-sec" value="ChatSecOps" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontStyle=1;size=8;" vertex="1" parent="group-t1">
          <mxGeometry x="90" y="192" width="80" height="22" as="geometry" />
        </mxCell>
        <mxCell id="t1-badge-dev" value="ChatDevOps" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;size=8;" vertex="1" parent="group-t1">
          <mxGeometry x="180" y="192" width="80" height="22" as="geometry" />
        </mxCell>

        <!-- ═══ TIER 2: Claude Code ═══ -->
        <mxCell id="group-t2" value="Tier 2 — Claude Code (Opus 4.6, 1M context)" style="swimlane;startSize=25;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;rounded=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="940" y="340" width="290" height="240" as="geometry" />
        </mxCell>
        <mxCell id="t2-desc" value="&lt;b&gt;Deep analysis: 2-10 minutes&lt;/b&gt;&lt;br&gt;&lt;br&gt;10 sub-agents (Anthropic Academy patterns):&lt;br&gt;triage-researcher • k8s-diagnostician&lt;br&gt;cisco-asa-specialist • storage-specialist&lt;br&gt;security-analyst (Opus) • code-explorer&lt;br&gt;code-reviewer • ci-debugger • dependency-analyst&lt;br&gt;workflow-validator&lt;br&gt;&lt;br&gt;&lt;i&gt;All agents write diary entries on completion&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;fontSize=10;" vertex="1" parent="group-t2">
          <mxGeometry x="10" y="30" width="270" height="140" as="geometry" />
        </mxCell>
        <mxCell id="t2-guard" value="&lt;b&gt;Guardrails:&lt;/b&gt; PreToolUse hooks (17 injection patterns) • 16 PII patterns&lt;br&gt;Tool call limit (75) • Cost ceiling ($25/day) • [POLL] before any change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="group-t2">
          <mxGeometry x="10" y="180" width="270" height="45" as="geometry" />
        </mxCell>

        <!-- ═══ TIER 3: Human ═══ -->
        <mxCell id="group-human" value="Tier 3 — Human (Matrix)" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;rounded=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1290" y="100" width="230" height="180" as="geometry" />
        </mxCell>
        <mxCell id="human-desc" value="&lt;b&gt;Approval Interface&lt;/b&gt;&lt;br&gt;&lt;br&gt;Interactive [POLL] (MSC3381)&lt;br&gt;Reactions: 👍 approve / 👎 reject&lt;br&gt;Reply: edit parameters&lt;br&gt;Timeout: 15min remind, 30min pause&lt;br&gt;&lt;br&gt;&lt;b&gt;Rooms:&lt;/b&gt; #infra-nl-prod&lt;br&gt;#infra-gr-prod • #cubeos • #meshsat" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;fontSize=10;" vertex="1" parent="group-human">
