        <mxCell id="mcp-list" value="&lt;b&gt;Infrastructure:&lt;/b&gt;&lt;br&gt;• netbox — CMDB (310 devices)&lt;br&gt;• kubernetes — kubectl (30+ tools)&lt;br&gt;• proxmox — PVE API (15 tools)&lt;br&gt;&lt;br&gt;&lt;b&gt;Development:&lt;/b&gt;&lt;br&gt;• codegraph — code analysis (KuzuDB)&lt;br&gt;• gitlab — MR, pipelines, commits&lt;br&gt;• opentofu / tfmcp — IaC&lt;br&gt;&lt;br&gt;&lt;b&gt;Platform:&lt;/b&gt;&lt;br&gt;• n8n-mcp — workflow management&lt;br&gt;• youtrack — issue CRUD&lt;br&gt;&lt;br&gt;&lt;i&gt;All audited against 8-point ACI checklist&lt;/i&gt;" style="text;html=1;align=left;spacingLeft=8;fontSize=9;verticalAlign=top;" vertex="1" parent="group-mcp">
          <mxGeometry x="10" y="30" width="210" height="230" as="geometry" />
