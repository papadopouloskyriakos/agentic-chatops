        <!-- ═══ TITLE ═══ -->
        <mxCell id="header" value="&lt;b&gt;agentic-chatops — Platform Architecture v2&lt;/b&gt;&lt;br&gt;3 Subsystems • 25 Workflows (475 nodes) • 10 MCP Servers (153 tools) • 10 Sub-Agents • 21 SQLite Tables (109K rows)" style="text;html=1;align=center;fontSize=15;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="15" width="1000" height="55" as="geometry" />
        </mxCell>

        <!-- ═══ ALERT SOURCES ═══ -->
        <mxCell id="group-alerts" value="Alert Ingestion Layer" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;rounded=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="230" height="430" as="geometry" />
        </mxCell>
        <mxCell id="node-librenms" value="&lt;b&gt;LibreNMS&lt;/b&gt;&lt;br&gt;NL: 137 devices • GR: 19 devices&lt;br&gt;16 + 19 alert rules" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="group-alerts">
          <mxGeometry x="15" y="40" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="node-prom" value="&lt;b&gt;Prometheus&lt;/b&gt;&lt;br&gt;Alertmanager (NL + GR)&lt;br&gt;K8s, etcd, node alerts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="group-alerts">
          <mxGeometry x="15" y="120" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="node-crowdsec" value="&lt;b&gt;CrowdSec&lt;/b&gt;&lt;br&gt;6 hosts, 54 scenarios&lt;br&gt;Auto-suppression learning loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="group-alerts">
          <mxGeometry x="15" y="200" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="node-vuln" value="&lt;b&gt;Vulnerability Scanners&lt;/b&gt;&lt;br&gt;NL + GR (cross-site)&lt;br&gt;24 tools, daily cron" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="group-alerts">
          <mxGeometry x="15" y="280" width="200" height="65" as="geometry" />
        </mxCell>
