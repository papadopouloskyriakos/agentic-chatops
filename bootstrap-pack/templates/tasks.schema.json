{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tasks.json for parallel-dev",
  "type": "object",
  "required": [
    "feature_id",
    "tasks"
  ],
  "properties": {
    "feature_id": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "title",
          "files_owned",
          "prompt",
          "dependencies",
          "parallelizable",
          "bounded_context",
          "acceptance_test",
          "risk_score"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^T-\\d{3,}$"
          },
          "title": {
            "type": "string",
            "minLength": 5
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "completed",
              "failed",
              "timeout",
              "skipped"
            ]
          },
          "files_owned": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "prompt": {
            "type": "string",
            "minLength": 10
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^T-\\d{3,}$"
            }
          },
          "parallelizable": {
            "type": "boolean"
          },
          "bounded_context": {
            "type": "string"
          },
          "requirement_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^REQ-\\d{3,}$"
            }
          },
          "acceptance_test": {
            "type": "string"
          },
          "complexity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "risk_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "max_wall_clock_minutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 120
          },
          "max_loc_delta": {
            "type": "integer",
            "minimum": 10,
            "maximum": 5000
          },
          "details": {
            "type": "string"
          }
        }
      }
    }
  }
}
