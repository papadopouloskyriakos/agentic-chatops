      },
      "memorySearch": {
        "enabled": true,
        "provider": "ollama",
        "model": "nomic-embed-text",
        "remote": {
          "baseUrl": "https://ollama.example.net",
          "apiKey": "ollama-local"
        }
      },
      "sandbox": {
        "mode": "off"
      },
      "elevatedDefault": "full",
