  "plugins": {
    "entries": {
      "matrix": {
        "enabled": true
      },
      "active-memory": {
        "enabled": true,
        "config": {
          "agents": ["main"],
          "allowedChatTypes": ["direct"],
          "model": "ollama/qwen3:30b-a3b",
          "modelFallbackPolicy": "default-remote",
          "queryMode": "recent",
          "promptStyle": "balanced",
          "timeoutMs": 15000,
          "maxSummaryChars": 220,
          "persistTranscripts": true,
          "logging": true,
          "thinking": "off",
          "recentUserTurns": 3,
          "recentAssistantTurns": 2
        }
      },
      "openai": {
        "enabled": true
      },
      "memory-core": {
        "enabled": true,
        "config": {
          "dreaming": {
            "enabled": true,
            "frequency": "0 3 * * *",
            "timezone": "UTC",
            "verboseLogging": false,
            "phases": {
              "light": {
                "enabled": true,
                "lookbackDays": 2,
                "dedupeSimilarity": 0.9
              },
              "rem": {
                "enabled": true,
                "lookbackDays": 7,
                "minPatternStrength": 0.75
              },
              "deep": {
                "enabled": true,
                "minScore": 0.8,
                "minRecallCount": 3,
                "minUniqueQueries": 3,
                "recencyHalfLifeDays": 14,
                "maxAgeDays": 30
              }
            }
          }
        }
      },
      "memory-wiki": {
        "enabled": true,
        "config": {
          "vaultMode": "bridge",
          "bridge": {
            "enabled": true,
            "readMemoryArtifacts": true,
            "indexDreamReports": true,
            "indexDailyNotes": true,
            "indexMemoryRoot": true,
            "followMemoryEvents": true
          },
          "unsafeLocal": {
            "allowPrivateMemoryCoreAccess": false,
            "paths": []
          },
          "search": {
            "backend": "shared",
            "corpus": "wiki"
          },
          "context": {
            "includeCompiledDigestPrompt": false
          }
        }
      },
      "webhooks": {
        "enabled": true,
        "config": {
          "routes": {
            "n8n-alert": {
              "enabled": true,
              "path": "/webhook/n8n-alert",
              "sessionKey": "n8n-alert-session",
              "secret": "REDACTED_02d2e954",
              "controllerId": "main",
              "description": "n8n alert intake — direct TaskFlow creation bypassing Matrix"
            }
          }
        }
      }
    }
