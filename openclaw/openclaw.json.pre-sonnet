        "mode": "safeguard",
        "provider": "ollama/qwen3:30b-a3b",
        "memoryFlush": {
          "enabled": true
        },
        "qualityGuard": {
          "enabled": true,
          "maxRetries": 2
        },
        "recentTurnsPreserve": 3
      },
      "embeddedPi": {
        "projectSettingsPolicy": "trusted",
        "executionContract": "strict-agentic"
      }
    }
  },
