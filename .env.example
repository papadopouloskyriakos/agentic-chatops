# claude-gateway environment configuration
# Copy to .env and fill in your values: cp .env.example .env
#
# Required variables are marked [REQUIRED]. Optional ones have defaults noted.

# ─── Core Services ───────────────────────────────────────────

# n8n workflow engine
N8N_URL=https://n8n.example.com                    # [REQUIRED] Your n8n instance URL
N8N_API_KEY=                                        # [REQUIRED] n8n API key (Settings → API)

# Matrix chat server (Synapse)
MATRIX_HOMESERVER=https://matrix.example.com        # [REQUIRED] Matrix homeserver URL
MATRIX_CLAUDE_TOKEN=                                # [REQUIRED] Bot access token (@claude user)
MATRIX_OPENCLAW_TOKEN=                              # [REQUIRED] Bot access token (@openclaw user)

# Matrix room IDs (create rooms first, then paste IDs)
MATRIX_ROOM_CHATOPS=!roomid:matrix.example.com      # [REQUIRED] #chatops — commands, fallback
MATRIX_ROOM_ALERTS=!roomid:matrix.example.com       # [REQUIRED] #alerts — system alerts
MATRIX_ROOM_INFRA=!roomid:matrix.example.com        # [REQUIRED] #infra-site1 — infrastructure alerts
MATRIX_ROOM_INFRA_GR=!roomid:matrix.example.com     # [OPTIONAL] #infra-site2 — second site (if multi-site)
MATRIX_ROOM_CUBEOS=!roomid:matrix.example.com       # [OPTIONAL] #project1 — dev project room
MATRIX_ROOM_MESHSAT=!roomid:matrix.example.com      # [OPTIONAL] #project2 — dev project room

# YouTrack issue tracking
YT_URL=https://youtrack.example.com                 # [REQUIRED] YouTrack instance URL
YT_TOKEN=                                           # [REQUIRED] YouTrack permanent token (Hub → Users → Tokens)

# ─── AI Models ───────────────────────────────────────────────

# Claude Code (Tier 2 — deep analysis)
ANTHROPIC_API_KEY=                                  # [REQUIRED] Anthropic API key for Claude Code + LLM-as-Judge

# OpenClaw / OpenAI (Tier 1 — fast triage)
OPENCLAW_MODEL=openai/gpt-5.1                       # [DEFAULT: openai/gpt-5.1] OpenClaw primary model
OPENCLAW_URL=http://localhost:18789                  # [DEFAULT: localhost] OpenClaw gateway URL
OPENCLAW_GATEWAY_TOKEN=                             # [REQUIRED if OpenClaw auth enabled]

# Ollama (local embeddings for RAG — optional but recommended)
OLLAMA_URL=http://gpu-host:11434                    # [OPTIONAL] Ollama API URL for embedding model
EMBED_MODEL=nomic-embed-text                        # [DEFAULT: nomic-embed-text] Embedding model name

# ─── Monitoring Sources ──────────────────────────────────────

# LibreNMS (primary site)
LIBRENMS_URL=https://nms.example.com                # [OPTIONAL] LibreNMS URL (for metrics scripts)
LIBRENMS_API_KEY=                                   # [OPTIONAL] LibreNMS API token

# LibreNMS (second site — if multi-site)
LIBRENMS_GR_URL=https://nms-site2.example.com       # [OPTIONAL]
LIBRENMS_GR_API_KEY=                                # [OPTIONAL]

# NetBox CMDB
NETBOX_URL=https://netbox.example.com               # [OPTIONAL] NetBox URL (used by triage scripts)
NETBOX_TOKEN=                                       # [OPTIONAL] NetBox API token

# ─── GitLab ──────────────────────────────────────────────────

GITLAB_URL=https://gitlab.example.com               # [OPTIONAL] GitLab instance
GITLAB_TOKEN=                                       # [OPTIONAL] GitLab personal access token

# ─── Infrastructure Access ───────────────────────────────────

# Cisco ASA firewall password (SSH + enable, also used as sudo password on VPS/scanners)
CISCO_ASA_PASSWORD=                                  # [REQUIRED] ASA SSH/enable password

# SSH host where Claude Code runs (n8n SSHes to this host)
CLAUDE_SSH_HOST=app-user-host                   # [REQUIRED] Hostname/IP of Claude Code runner
CLAUDE_SSH_USER=app-user                        # [DEFAULT: app-user] SSH username
CLAUDE_SSH_KEY_ID=                                   # [REQUIRED] n8n SSH credential ID

# IaC repository paths on the Claude Code host
IAC_REPO_SITE1=/app/infrastructure/site1/production
IAC_REPO_SITE2=/app/infrastructure/site2/production

# ─── Paths ───────────────────────────────────────────────────

# SQLite database (auto-created if missing)
GATEWAY_DB=/home/app-user/claude-context/gateway.db

# Prometheus textfile collector directory
PROM_TEXTFILE_DIR=/var/lib/node_exporter/textfile_collector

# Gateway mode file (controls frontend/backend pair)
GATEWAY_MODE_FILE=/home/app-user/gateway.mode

# Maintenance mode file (JSON, created/removed by maintenance playbooks)
GATEWAY_MAINT_FILE=/home/app-user/gateway.maintenance

# ─── Budget & Limits ─────────────────────────────────────────

MAX_SESSION_COST_EUR=5                              # [DEFAULT: 5] Per-session cost ceiling (EUR)
MAX_DAILY_COST_USD=25                               # [DEFAULT: 25] Daily budget → plan-only mode
MAX_TOOL_CALLS=75                                   # [DEFAULT: 75] Per-session tool call limit

# ─── Security Scanners (optional) ────────────────────────────

# Only needed if using ChatSecOps (security alert pipelines)
SCANNER_SSH_KEY=~/.ssh/one_key                      # SSH key for scanner VMs
SCANNER_SUDO_PASS=                                  # sudo password on scanner VMs
SCANNER_NL_IP=                                      # NL scanner VM IP
SCANNER_GR_IP=                                      # GR scanner VM IP

# ─── AWX (optional) ──────────────────────────────────────────

# Only needed if using AWX for maintenance automation
AWX_URL=https://awx.example.com
AWX_TOKEN=
GR_AWX_TOKEN=
