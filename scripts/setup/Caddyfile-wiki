# Example Corp Wiki (IFRNLLEI01PRD-654 follow-up).
# Serves the mkdocs-material build at wiki-site/site/ on :8080 bound to
# VLAN IP. TLS is terminated upstream by nginx-proxy-manager for
# https://wiki.example.net/.
{
	auto_https off
}

:8080 {
	root * /app/claude-gateway/wiki-site/site

	encode gzip zstd

	file_server {
		hide .*
	}

	# Cache rendered HTML for 5 min so rebuild picks up reasonably fast.
	header Cache-Control "public, max-age=300"
	# Static assets (fonts, icons) — cache aggressively.
	@static path *.css *.js *.woff *.woff2 *.ttf *.ico *.png *.jpg *.svg
	header @static Cache-Control "public, max-age=86400"

	log {
		output file /var/log/caddy/wiki-access.log {
			roll_size 50mb
			roll_keep 3
		}
		format json
		level INFO
	}

	# 404 falls back to 404.html if mkdocs built one; otherwise Caddy default.
	handle_errors {
		@404 expression {err.status_code} == 404
		rewrite @404 /404.html
		file_server
	}
}
