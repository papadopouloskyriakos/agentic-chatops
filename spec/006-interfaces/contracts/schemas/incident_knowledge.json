{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.net/schemas/incident_knowledge.json",
  "title": "incident_knowledge",
  "description": "Learned suppression/known-pattern knowledge (REQ-301, REQ-401).",
  "type": "object",
  "required": ["hostname", "rule", "confidence", "schema_version"],
  "additionalProperties": true,
  "properties": {
    "hostname": { "type": "string" },
    "rule": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "suppression_status": { "type": "string" },
    "demotion_reason": { "type": ["string", "null"] },
    "schema_version": { "type": "integer", "minimum": 1 }
  }
}
