{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.net/schemas/infragraph_dynamics.json",
  "title": "infragraph_dynamics",
  "description": "Predicted-vs-actual cascade edge dynamics (REQ-103, REQ-104).",
  "type": "object",
  "required": ["src", "dst", "confidence"],
  "additionalProperties": true,
  "properties": {
    "src": { "type": "string" },
    "dst": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "invalid_at": { "type": ["string", "null"] },
    "superseded_by": { "type": ["integer", "null"] }
  }
}
